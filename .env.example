# ─── Copy this file to .env and fill in values ───────────────────────────────
# NEVER commit .env to git

# ─── Project ─────────────────────────────────────────────────────────────────
PROJECT_NAME=my-project
PROJECT_PROFILE=startup              # solo | startup | enterprise
PRIMARY_LANGUAGE=typescript          # typescript | go | python | rust

# ─── Database ────────────────────────────────────────────────────────────────
DB_PROVIDER=postgresql               # postgresql | mysql | sqlite
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://app:change_me@localhost:5432/app

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_long
REFRESH_TOKEN_SECRET=change_me_min_32_chars_long
JWT_EXPIRES_IN=15m
AUTH_STRATEGY=jwt                    # jwt | oauth | api-key

# ─── Services (internal URLs) ────────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
CORE_SERVICE_URL=http://core-service:3002
WORKER_SERVICE_URL=http://worker-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3004

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=My Project

# ─── Email (notification-service) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=info                       # debug | info | warn | error
NODE_ENV=development
